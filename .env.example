# ============================================================================
# AI Civilization Engine — single shared config template
# cp .env.example .env   (never commit .env)
# Precedence everywhere: process env > this file > in-repo defaults.
# ============================================================================

# --- Minecraft (THE pin — see docs/architecture/05-repository-devops.md §3) ---
# Change only via the atomic upgrade PR that also bumps mineflayer.
MC_VERSION=1.21.6
# Containers reach the host-run server via host.docker.internal.
# Switch to 'minecraft' + `--profile minecraft` for the containerized PaperMC.
MC_HOST=host.docker.internal
MC_PORT=25565

# --- Kafka (Redpanda) ---
# Host-run services use localhost:9092; compose overrides to redpanda:29092
# for containerized services (internal listener).
KAFKA_BROKERS=localhost:9092

# --- PostgreSQL (one instance, five logical DBs — see postgres-init) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_PASSWORD=civ_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- LLM ---
# Fallback chain: openai -> ollama -> fake (boot-time reachability probe).
# Blank OPENAI_API_KEY is fine — agent-service degrades to Ollama, then fake.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_OLLAMA=llama3.1:8b
EMBEDDING_MODEL_OPENAI=text-embedding-3-small
EMBEDDING_MODEL_OLLAMA=nomic-embed-text
# Hard daily ceiling — hitting it flips the provider to 'fake' (circuit breaker).
LLM_DAILY_TOKEN_BUDGET=2000000

# --- Simulation ---
TICK_INTERVAL_SECONDS=60
VILLAGER_COUNT=1

# --- Observability ---
LOG_LEVEL=info
