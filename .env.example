# ============================================================================
# AI Civilization Engine — single shared config template
# cp .env.example .env   (never commit .env)
# Precedence everywhere: process env > this file > in-repo defaults.
# ============================================================================

# --- Minecraft (THE pin — see docs/architecture/05-repository-devops.md §3) ---
# Change only via the atomic upgrade PR that also bumps mineflayer.
MC_VERSION=1.21.6
# Containers reach the host-run server via host.docker.internal.
# Switch to 'minecraft' + `--profile minecraft` for the containerized PaperMC.
MC_HOST=host.docker.internal
MC_PORT=25565

# --- Kafka (Redpanda) ---
# Host-run services use localhost:9092; compose overrides to redpanda:29092
# for containerized services (internal listener).
KAFKA_BROKERS=localhost:9092

# --- PostgreSQL (one instance, five logical DBs — see postgres-init) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_PASSWORD=civ_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- LLM ---
# Fallback chain: openai -> ollama -> fake (boot-time reachability probe).
# Blank OPENAI_API_KEY is fine — agent-service degrades to Ollama, then fake.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_OLLAMA=llama3.1:8b
# Max in-flight completion calls from agent-service — extra ticks queue at the
# provider (intentional backpressure: 20 parallel calls thrash one Ollama GPU).
LLM_MAX_CONCURRENT_REQUESTS=4
EMBEDDING_MODEL_OPENAI=text-embedding-3-small
EMBEDDING_MODEL_OLLAMA=nomic-embed-text
# Hard daily ceiling — hitting it flips deliberation to 'fake' (circuit
# breaker). 2M is sized for PAID providers (~$0.45/day at gpt-4o-mini). On
# free local Ollama, 20 villagers burn ~3.5k tokens/tick ≈ 2M in ~30 MINUTES
# and the fake fallback then POLLUTES narrative state (scripted chats and
# relationship nudges) — for Ollama runs set this to 100000000.
LLM_DAILY_TOKEN_BUDGET=2000000
# Per-team brains (RB filming): "red=llama3.1:8b,blue=gemma3:12b" routes each
# race team's deliberation to its own warmed Ollama model; villagers outside a
# team (or pre-race) stay on the chain above. Blank = off. Strict at boot:
# malformed spec or an unpulled model refuses to start (a silently degraded
# team brain would poison a filmed race). Each team gets its own budget breaker.
LLM_TEAM_MODELS=
# KV-cache ceiling per request (Ollama num_ctx). Prompts run 3-5k tokens;
# 8192 keeps two team models resident together on a 24 GB GPU. An unset host
# default can balloon (observed 65536 = 13 GB VRAM for one 8B model).
OLLAMA_NUM_CTX=8192

# --- Reflections (memory-service, M1-9) ---
# Budgets are per service: this breaker is separate from the deliberation one
# above, and a trip PAUSES reflections (no fake fallback — reflections are
# permanent narrative memory). The hourly cap is global, bounding GPU load
# when the chain lands on Ollama.
REFLECTION_ENABLED=true
REFLECTION_DAILY_TOKEN_BUDGET=200000
REFLECTIONS_PER_HOUR_CAP=12

# --- Simulation ---
TICK_INTERVAL_SECONDS=60
# Red-vs-Blue race preset (ADR-10): VILLAGER_COUNT=6 seeds exactly the two
# rosters (red: Elara/Bram/Wren, blue: Ansel/Petra/Fen — the `team` field in
# seed/villagers.json). Dev default stays 1; fleet ≤5 outside race work.
VILLAGER_COUNT=1

# --- Observability ---
LOG_LEVEL=info
