{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ai-civilization-engine.local/world/VillagerMoved.v1.schema.json",
  "title": "VillagerMovedPayload",
  "description": "Throttled at source: at most one per 5s while moving, plus one on path completion. Producer: minecraft-service on world.events.",
  "type": "object",
  "properties": {
    "villagerId": { "type": "string", "format": "uuid" },
    "from": { "$ref": "#/$defs/Position" },
    "to": { "$ref": "#/$defs/Position" },
    "distance": { "type": "number", "minimum": 0 }
  },
  "required": ["villagerId", "from", "to", "distance"],
  "additionalProperties": false,
  "$defs": {
    "Position": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "required": ["x", "y", "z"],
      "additionalProperties": false
    }
  }
}
