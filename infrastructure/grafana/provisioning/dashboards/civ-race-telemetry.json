{
  "uid": "civ-race",
  "title": "Red vs Blue — Race Telemetry",
  "tags": [
    "ai-civilization-engine",
    "recruiter-demo"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Race progress — milestones crossed by team",
      "description": "Five fixed rungs (ADR-10): first coal, first iron ore, furnace placed, first ingot, iron pickaxe (=win). Each crossing is a ProgressionMilestone event in the append-only ledger.",
      "gridPos": {
        "h": 9,
        "w": 14,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (team) (civ_progression_milestones_total)",
          "legendFormat": "{{team}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Milestones crossed (range)",
      "description": "Rungs per team inside the dashboard range.",
      "gridPos": {
        "h": 9,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0
        }
      },
      "targets": [
        {
          "expr": "sum by (team) (increase(civ_progression_milestones_total[$__range]))",
          "legendFormat": "{{team}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bots / players tracked / lane depth",
      "description": "civ_command_lane_depth idles at 0 — sustained >6 at a 6-bot race means the world is falling behind the brains.",
      "gridPos": {
        "h": 9,
        "w": 5,
        "x": 19,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0
        }
      },
      "targets": [
        {
          "expr": "civ_bot_sessions",
          "legendFormat": "bots"
        },
        {
          "expr": "sum(civ_players_tracked)",
          "legendFormat": "players tracked"
        },
        {
          "expr": "civ_command_lane_depth",
          "legendFormat": "lane depth"
        }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Top collectors — items gained (range)",
      "description": "Positive inventory deltas between polls, per player.",
      "gridPos": {
        "h": 9,
        "w": 10,
        "x": 0,
        "y": 9
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0
        }
      },
      "targets": [
        {
          "expr": "topk(6, sum by (player) (increase(civ_materials_collected_total[$__range])))",
          "legendFormat": "{{player}}",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Collection rate by player (items/min)",
      "description": "The gather bursts line up with the rungs.",
      "gridPos": {
        "h": 9,
        "w": 14,
        "x": 10,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum by (player) (rate(civ_materials_collected_total[2m])) * 60",
          "legendFormat": "{{player}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Command lane depth",
      "description": "Commands admitted to per-villager dispatch lanes but not yet finished (RB-2).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "civ_command_lane_depth",
          "legendFormat": "lane depth"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "World events emitted by type",
      "description": "world.events facts published by the single world executor (mineflayer).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(civ_world_events_emitted_total[1m]))",
          "legendFormat": "{{type}}"
        }
      ]
    }
  ]
}