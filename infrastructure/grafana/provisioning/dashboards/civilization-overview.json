{
  "uid": "civ-overview",
  "title": "Civilization Overview",
  "tags": ["ai-civilization-engine"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Event throughput (events/s by topic)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (topic) (rate(civ_events_ingested_total[1m]))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Decision latency p95 (s, by provider)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(civ_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "LLM tokens/min",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (direction) (rate(civ_llm_tokens_total[5m])) * 60",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "LLM spend (range, USD)",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "targets": [
        {
          "expr": "sum(increase(civ_llm_cost_dollars_total{run_mode=\"compose\"}[$__range]))",
          "legendFormat": "spend"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory retrieval p95 (s)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(civ_memory_retrieval_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Kafka consumer lag (records)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum by (client_id) (kafka_consumer_fetch_manager_records_lag)",
          "legendFormat": "{{client_id}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cognitive tick duration p95 (s)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(civ_tick_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Ticks/min by outcome",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(civ_ticks_total[5m])) * 60",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Bots / SSE clients / budget breaker",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        { "expr": "civ_bot_sessions", "legendFormat": "bots" },
        { "expr": "civ_sse_clients", "legendFormat": "sse clients" },
        { "expr": "civ_llm_budget_tripped", "legendFormat": "budget tripped" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Reactive tick ratio (cap arithmetic says < ~0.4 sustained)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } },
      "targets": [
        {
          "expr": "sum(rate(civ_ticks_total{trigger=\"reactive\"}[5m])) / sum(rate(civ_ticks_total[5m]))",
          "legendFormat": "reactive / all ticks"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "LLM spend by service (range, USD)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "targets": [
        {
          "expr": "sum by (job) (increase(civ_llm_cost_dollars_total{run_mode=\"compose\"}[$__range]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Reflections by outcome (memory-service)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        {
          "expr": "sum by (outcome) (increase(civ_reflections_total{run_mode=\"compose\"}[$__range]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    }
  ]
}
